# folio – environment configuration example.
# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# App
APP_HTTP_ADDRESS=127.0.0.1:8080
APP_EDITOR="John Doe"

# SMTP
SMTP_USERNAME=jdoe@example.tld
SMTP_PASSWORD=your_smtp_password
SMTP_RELAY=smtp.example.tld
SMTP_PORT=587

# Git
# PAT with: read contents, write issues, read webhooks
# Scoped to a single repository.
GIT_TOKEN=ghp_your_personal_access_token
GIT_OWNER=jdoe
GIT_REPOSITORY=knowledge_base
GIT_BRANCH=main

# Umami analytics
UMAMI_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
